# =============================================================================
# CERTIFICATION PROJECT — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control!
#
# Usage:
#   cp .env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC / CLAUDE AI
# -----------------------------------------------------------------------------
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="your-api-key-here"

# -----------------------------------------------------------------------------
# NEXT.JS FRONTEND (apps/web)
# -----------------------------------------------------------------------------
# The public URL of the deployed Next.js app (used for absolute redirects, OG, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# URL of the FastAPI backend — used by Next.js server-side code to call the API
NEXT_PUBLIC_API_URL="http://localhost:8000"

# -----------------------------------------------------------------------------
# FASTAPI BACKEND (apps/api)
# -----------------------------------------------------------------------------
# Host and port the FastAPI dev server will bind to
API_HOST="0.0.0.0"
API_PORT="8000"

# Comma-separated list of origins allowed to call the API (CORS)
# In production, replace with your real Cloudflare Pages URL
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# App environment: development | staging | production
APP_ENV="development"

# -----------------------------------------------------------------------------
# CLOUDFLARE (deployment)
# -----------------------------------------------------------------------------
# Your Cloudflare Account ID — found in the Cloudflare dashboard sidebar
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# API token with "Pages:Edit" permission
# Create one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# Cloudflare Pages project name for the Next.js frontend
CLOUDFLARE_PROJECT_NAME="claude-certification-web"

# -----------------------------------------------------------------------------
# OPTIONAL — Database / Storage (add as needed)
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
# REDIS_URL="redis://localhost:6379"
