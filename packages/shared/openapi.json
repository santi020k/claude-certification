{
  "components": {
    "schemas": {
      "AccessibilityAnalyzeRequest": {
        "description": "Body expected by POST /api/accessibility/analyze.",
        "properties": {
          "code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional source code. If empty, the backend will attempt to read the file from the workspace.",
            "title": "Code"
          },
          "file_path": {
            "description": "Path relative to the workspace root or filename.",
            "title": "File Path",
            "type": "string"
          }
        },
        "required": [
          "file_path"
        ],
        "title": "AccessibilityAnalyzeRequest",
        "type": "object"
      },
      "AccessibilityAnalyzeResponse": {
        "description": "Response returned by POST /api/accessibility/analyze.",
        "properties": {
          "file_path": {
            "description": "The path of the analyzed file.",
            "title": "File Path",
            "type": "string"
          },
          "input_tokens": {
            "description": "Prompt tokens consumed.",
            "title": "Input Tokens",
            "type": "integer"
          },
          "model": {
            "description": "The Claude model used for analysis.",
            "title": "Model",
            "type": "string"
          },
          "output_tokens": {
            "description": "Completion tokens consumed.",
            "title": "Output Tokens",
            "type": "integer"
          },
          "summary": {
            "description": "A markdown summary of the audit and findings.",
            "title": "Summary",
            "type": "string"
          },
          "violations": {
            "description": "List of detected accessibility violations.",
            "items": {
              "$ref": "#/components/schemas/AccessibilityViolation"
            },
            "title": "Violations",
            "type": "array"
          }
        },
        "required": [
          "file_path",
          "violations",
          "summary",
          "model",
          "input_tokens",
          "output_tokens"
        ],
        "title": "AccessibilityAnalyzeResponse",
        "type": "object"
      },
      "AccessibilityViolation": {
        "description": "Represents a specific accessibility issue detected in the code.",
        "properties": {
          "description": {
            "description": "Explanation of the accessibility issue.",
            "title": "Description",
            "type": "string"
          },
          "element": {
            "description": "The code snippet or element causing the violation.",
            "title": "Element",
            "type": "string"
          },
          "line": {
            "description": "Line number where the violation is found, or 0 if general.",
            "title": "Line",
            "type": "integer"
          },
          "recommendation": {
            "description": "Actionable suggestion to resolve the issue.",
            "title": "Recommendation",
            "type": "string"
          },
          "severity": {
            "description": "Severity (critical, serious, moderate, minor)",
            "title": "Severity",
            "type": "string"
          },
          "type": {
            "description": "Type of violation (e.g., contrast, semantic, keyboard, etc.)",
            "title": "Type",
            "type": "string"
          },
          "wcag_guideline": {
            "description": "WCAG 2.2 guideline reference (e.g., 1.4.3 Contrast)",
            "title": "Wcag Guideline",
            "type": "string"
          }
        },
        "required": [
          "line",
          "element",
          "type",
          "severity",
          "wcag_guideline",
          "description",
          "recommendation"
        ],
        "title": "AccessibilityViolation",
        "type": "object"
      },
      "AskRequest": {
        "description": "Body expected by POST /api/ask.",
        "properties": {
          "max_tokens": {
            "default": 1000,
            "description": "Upper limit on Claude's response length (tokens).",
            "maximum": 4000.0,
            "minimum": 50.0,
            "title": "Max Tokens",
            "type": "integer"
          },
          "one_sentence": {
            "default": false,
            "description": "When True, instructs Claude to answer in a single sentence.",
            "title": "One Sentence",
            "type": "boolean"
          },
          "question": {
            "description": "The question you want Claude to answer.",
            "examples": [
              "Explain Python decorators in simple terms"
            ],
            "maxLength": 4000,
            "minLength": 3,
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question"
        ],
        "title": "AskRequest",
        "type": "object"
      },
      "AskResponse": {
        "description": "Response returned by POST /api/ask and GET /api/ask/demo.",
        "properties": {
          "answer": {
            "description": "Claude's answer.",
            "title": "Answer",
            "type": "string"
          },
          "input_tokens": {
            "description": "Prompt tokens consumed (for billing reference).",
            "title": "Input Tokens",
            "type": "integer"
          },
          "model": {
            "description": "The Claude model that generated the answer.",
            "title": "Model",
            "type": "string"
          },
          "output_tokens": {
            "description": "Completion tokens consumed (for billing reference).",
            "title": "Output Tokens",
            "type": "integer"
          },
          "question": {
            "description": "The original question that was sent to Claude.",
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question",
          "answer",
          "model",
          "input_tokens",
          "output_tokens"
        ],
        "title": "AskResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Response returned by GET /api/health.",
        "properties": {
          "allowed_origins": {
            "items": {
              "type": "string"
            },
            "title": "Allowed Origins",
            "type": "array"
          },
          "anthropic_api_key_configured": {
            "title": "Anthropic Api Key Configured",
            "type": "boolean"
          },
          "environment": {
            "title": "Environment",
            "type": "string"
          },
          "model": {
            "title": "Model",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "environment",
          "anthropic_api_key_configured",
          "model",
          "allowed_origins"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "REST API wrapping Anthropic Claude \u2014 learning / certification project.\n\nInteractive docs \u2192 **/docs** (Swagger UI) or **/redoc** (ReDoc).\n\n**Rate limits** (per remote IP):\n- `POST /api/ask` \u2014 10/minute\n- `GET /api/ask/demo` \u2014 5/minute\n",
    "title": "Certification API",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Root endpoint \u2014 quick sanity check.\n\nPaste `http://localhost:8000/` in a browser to confirm the server is up.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Root",
        "tags": [
          "health"
        ]
      }
    },
    "/api/accessibility/analyze": {
      "post": {
        "description": "Analyze a workspace file or code snippet for accessibility violations using Claude.\n\n**Rate limit:** 10 requests per minute per IP.\n\n**Example request body**\n```json\n{\n  \"file_path\": \"apps/web/src/app/globals.css\"\n}\n```",
        "operationId": "analyze_file_accessibility_api_accessibility_analyze_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccessibilityAnalyzeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessibilityAnalyzeResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Analyze File Accessibility",
        "tags": [
          "accessibility"
        ]
      }
    },
    "/api/ask": {
      "post": {
        "description": "Send any question to Claude and receive a structured JSON answer.\n\n**Rate limit:** 10 requests per minute per IP.\n\n**Example request body**\n```json\n{\n  \"question\": \"Explain Python decorators in simple terms\",\n  \"max_tokens\": 500,\n  \"one_sentence\": false\n}\n```\n\nWhen `one_sentence` is `true`, the question is prefixed with a brevity\ninstruction so Claude keeps its reply to a single sentence \u2014 handy for\nquick demos or UI cards.",
        "operationId": "ask_question_api_ask_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Ask Question",
        "tags": [
          "claude"
        ]
      }
    },
    "/api/ask/demo": {
      "get": {
        "description": "Runs the classic quickstart demo question:\n*\"What is quantum computing? Answer in one sentence.\"*\n\n**Rate limit:** 5 requests per minute per IP.\n\nThis is a GET endpoint so you can test it directly in a browser or with:\n\n```bash\ncurl http://localhost:8000/api/ask/demo\n```\n\nNo request body needed.",
        "operationId": "ask_demo_api_ask_demo_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Ask Demo",
        "tags": [
          "claude"
        ]
      }
    },
    "/api/health": {
      "get": {
        "description": "Detailed health check \u2014 returns environment info.\n\n**Never** exposes the actual API key value; only reports whether it's set.\nSafe to call from monitoring tools or a frontend status page.",
        "operationId": "health_check_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Check",
        "tags": [
          "health"
        ]
      }
    }
  }
}
