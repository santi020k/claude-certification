{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@ui/components/*": ["../../packages/ui/src/components/*"],
      "@ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@repo/shared": ["../../packages/shared/src/index.ts"],
      "@repo/ui/components/*": ["../../packages/ui/src/components/*"],
      "@repo/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@repo/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@repo/ui/globals.css": ["../../packages/ui/src/globals.css"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
